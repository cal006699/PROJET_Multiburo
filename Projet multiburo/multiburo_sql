-- Création de la base de données
CREATE DATABASE IF NOT EXISTS multiburo_calvin;
USE multiburo_calvin;

-- Création des tables
CREATE TABLE TYPE_RESSOURCE (
    id_type INT,
    lib VARCHAR(30) NOT NULL,
    CONSTRAINT pk_type_ressource PRIMARY KEY(id_type)
);

CREATE TABLE USER (
    id_user INT,
    nom VARCHAR(30),
    prenom VARCHAR(30),
    CONSTRAINT pk_user PRIMARY KEY(id_user)
);

CREATE TABLE RESSOURCE (
    id_ressource INT,
    lib VARCHAR(30),
    nb_place INT,
    id_type INT,
    CONSTRAINT pk_ressource PRIMARY KEY(id_ressource),
    CONSTRAINT fk_ressource FOREIGN KEY(id_type) REFERENCES TYPE_RESSOURCE(id_type)
);

CREATE TABLE RESERVATION (
    id_ressource INT,
    id_user INT,
    date DATE,
    CONSTRAINT pk_reservation PRIMARY KEY(id_ressource, id_user, date),
    CONSTRAINT fk_reservation_R FOREIGN KEY(id_ressource) REFERENCES RESSOURCE(id_ressource),
    CONSTRAINT fk_reservation_U FOREIGN KEY(id_user) REFERENCES USER(id_user)
);

